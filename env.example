# Datadog Configuration
# Replace with your actual Datadog API key from: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your_datadog_api_key_here

# Datadog Site (choose based on your region)
# US1: datadoghq.com (default)
# US3: us3.datadoghq.com  
# US5: us5.datadoghq.com
# EU1: datadoghq.eu
# AP1: ap1.datadoghq.com
DD_SITE=datadoghq.com

# Environment and version for tagging
DD_ENV=development
DD_VERSION=1.0.0
DD_HOSTNAME=otel-simple-server

# Application Configuration  
SERVICE_NAME=simple-python-server
SERVICE_VERSION=1.0.0
